37835>>>>>>>    Procedure SetActionButtons
37838>>>>>>>        tWebNavigateData NavigateData
37838>>>>>>>        tWebNavigateData NavigateData
37838>>>>>>>        Boolean bHasRecord
37838>>>>>>>        Handle hoDD
37838>>>>>>>
37838>>>>>>>        Get Server to hoDD
37839>>>>>>>        Get GetNavigateData to NavigateData
37840>>>>>>>        Get HasRecord of hoDD to bHasRecord
37841>>>>>>>
37841>>>>>>>        // let's hide all buttons and then Show the ones we want
37841>>>>>>>        WebSet pbRender of oEditBtn to False
37842>>>>>>>        WebSet pbRender of oSaveBtn to False
37843>>>>>>>        WebSet pbRender of oCancelChangesBtn to False
37844>>>>>>>        WebSet pbRender of oDeleteBtn to False
37845>>>>>>>
37845>>>>>>>        If (NavigateData.bReadOnly) Begin
37847>>>>>>>            WebSet pbRender of oEditBtn to True
37848>>>>>>>        End
37848>>>>>>>>
37848>>>>>>>        Else Begin
37849>>>>>>>            WebSet pbRender of oSaveBtn to True
37850>>>>>>>            WebSet pbRender of oCancelChangesBtn to True
37851>>>>>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37852>>>>>>>        End
37852>>>>>>>>
37852>>>>>>>    End_Procedure
37853>>>>>>>
