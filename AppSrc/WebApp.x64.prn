37527>>>>>>>    Procedure SetActionButtons
37530>>>>>>>        tWebNavigateData NavigateData
37530>>>>>>>        tWebNavigateData NavigateData
37530>>>>>>>        Boolean bHasRecord
37530>>>>>>>        Handle hoDD
37530>>>>>>>
37530>>>>>>>        Get Server to hoDD
37531>>>>>>>        Get GetNavigateData to NavigateData
37532>>>>>>>        Get HasRecord of hoDD to bHasRecord
37533>>>>>>>
37533>>>>>>>        // let's hide all buttons and then Show the ones we want
37533>>>>>>>        WebSet pbRender of oEditBtn to False
37534>>>>>>>        WebSet pbRender of oSaveBtn to False
37535>>>>>>>        WebSet pbRender of oCancelChangesBtn to False
37536>>>>>>>        WebSet pbRender of oDeleteBtn to False
37537>>>>>>>
37537>>>>>>>        If (NavigateData.bReadOnly) Begin
37539>>>>>>>            WebSet pbRender of oEditBtn to True
37540>>>>>>>        End
37540>>>>>>>>
37540>>>>>>>        Else Begin
37541>>>>>>>            WebSet pbRender of oSaveBtn to True
37542>>>>>>>            WebSet pbRender of oCancelChangesBtn to True
37543>>>>>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37544>>>>>>>        End
37544>>>>>>>>
37544>>>>>>>    End_Procedure
37545>>>>>>>
37545>>>>>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
37548>>>>>>>        // Close after save
37548>>>>>>>        Send NavigateClose Self
37549>>>>>>>    End_Procedure
37550>>>>>>>
37550>>>>>>>    // this will close the view after a delete
37550>>>>>>>    Procedure OnViewDeleted Handle hoDDO
37553>>>>>>>        Send NavigateClose Self
37554>>>>>>>    End_Procedure
37555>>>>>>>
37555>>>>>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37558>>>>>>>        Case Begin
37558>>>>>>>            Case (NavigateData.eNavigateType = nfFromMain)
37560>>>>>>>                // If from main, this is a propbably a main file Select to Zoom.
37560>>>>>>>                Case Break
37561>>>>>>>
37561>>>>>>>            Case (NavigateData.eNavigateType = nfFromParent)
37564>>>>>>>                // If from parent, this is a constrained drill down.
37564>>>>>>>                Case Break
37565>>>>>>>
37565>>>>>>>            Case (NavigateData.eNavigateType = nfFromChild)
37568>>>>>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37568>>>>>>>                Case Break
37569>>>>>>>
37569>>>>>>>            Case Else // must be nfUndefined
37569>>>>>>>
37569>>>>>>>        Case End
37569>>>>>>>
37569>>>>>>>        Send SetActionButtons
37570>>>>>>>
37570>>>>>>>    End_Procedure
37571>>>>>>>
37571>>>>>>>End_Object 
